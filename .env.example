# API
APP_PORT=5000

# Model server (docker-compose injects vllm service name automatically)
VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=8192
VLLM_API_KEY=token-abc123
DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGING_FACE_HUB_TOKEN=
HF_HOME=./.cache/huggingface
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Embedding service (external by default)
EMBED_URL=http://host.docker.internal:8080/embed
RAG_QUERY_ENCODER=

# Qdrant for app container and exposed ports
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=seoul_plan
QDRANT_VECTOR_NAMES=text_dense,caption_dense,object_dense
QDRANT_RETRIEVAL_CONFIG=
CHUNKING_DOCS_PACKAGE_DIR=
BM25_TOKENS_PATH=
QDRANT_IMAGE=qdrant/qdrant:latest
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_DATA_PATH=./.local/qdrant

# App runtime
MAX_TOKENS=4096
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=

# Monitoring
PROMETHEUS_PORT=9090
PROMETHEUS_DATA_PATH=./.local/prometheus
GRAFANA_PORT=3000
GRAFANA_DATA_PATH=./.local/grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8081
