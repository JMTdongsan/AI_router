# API
APP_PORT=5000

# Model server (docker-compose injects vllm service name automatically)
VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=8192
VLLM_API_KEY=token-abc123
DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGING_FACE_HUB_TOKEN=
HF_HOME=./.cache/huggingface
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Embedding service (external by default)
EMBED_URL=http://host.docker.internal:8080/embed

# Milvus for app container and exposed ports
MILVUS=milvus
MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091
MILVUS_DATA_PATH=./.local/milvus
ETCD_DATA_PATH=./.local/etcd
MINIO_DATA_PATH=./.local/minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# App runtime
MAX_TOKENS=4096
